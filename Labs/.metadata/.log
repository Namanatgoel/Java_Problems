import java.util.Scanner;
public class Mixer {
int arr[];
void accept() {
	Scanner sc = new Scanner(System.in);
	System.out.println("Enter number of elements");
	int n = sc.nextInt();
	arr = new int[n];
	System.out.println("Enter elements in ascending order");
	for(int i = 0 ; i<n;i++)
	{
		arr[i] = sc.nextInt();
	}
	
}	
	
	
Mixer mix(Mixer A) {
	int i=0,k=0,j=0;
	Mixer q = new Mixer();
	int n1 = this.arr.length;
	int n2 = A.arr.length;
	q.arr = new int[n1+n2];
    while(i<n1&&j<n2) {
    	if(this.arr[i]>A.arr[j]) {
    		q.arr[k++]=A.arr[j++];
    		
    	}
    	else if(A.arr[j]>this.arr[i]) {
    			q.arr[k++]= this.arr[i++];
    			
