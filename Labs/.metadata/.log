    		j++;
    	}
    	 (i<n1) {
    		  q.arr[k++]=this.arr[i++]; 
    	   }
    	}
  
    return q;
    }
  void display()
  {
	  for(int x:arr) {
		  System.out.println(x);
	  }
  }


